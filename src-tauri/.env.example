# Committed example for the sqlx offline cache. `scripts/setup.sh` copies this
# to src-tauri/.env (gitignored) and runs `scripts/setup-dev-db.sh` to create +
# migrate the DB, so `cargo sqlx prepare --check` (pre-push Phase E) works
# locally. Re-run that script after pulling new migrations to refresh the schema.
DATABASE_URL=sqlite:dev.db
