{
  "$schema": "../gen/schemas/capabilities.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "opener:allow-open-url",
    "process:default",
    "clipboard-manager:allow-write-text",
    "os:default",
    "notification:default",
    "global-shortcut:default",
    "deep-link:default",
    "autostart:default",
    "updater:default"
  ]
}
