{
  "db_name": "SQLite",
  "query": "WITH RECURSIVE page_blocks(id, depth) AS ( SELECT id, 0 FROM blocks WHERE id = ?1 UNION ALL SELECT b.id, pb.depth + 1 FROM blocks b JOIN page_blocks pb ON b.parent_id = pb.id WHERE pb.depth < 100 ) SELECT ol.device_id, ol.seq, ol.op_type, ol.payload, ol.created_at, ol.is_replicated AS \"is_replicated!: bool\" FROM op_log ol WHERE ol.block_id IN (SELECT id FROM page_blocks) AND (?2 IS NULL OR ol.op_type = ?2) AND (?3 IS NULL OR ( ol.created_at < ?4 OR (ol.created_at = ?4 AND ol.seq < ?5) OR (ol.created_at = ?4 AND ol.seq = ?5 AND ol.device_id < ?7))) ORDER BY ol.created_at DESC, ol.seq DESC, ol.device_id DESC LIMIT ?6",
