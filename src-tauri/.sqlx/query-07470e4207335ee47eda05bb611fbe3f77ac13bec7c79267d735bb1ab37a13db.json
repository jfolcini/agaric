{
  "db_name": "SQLite",
  "query": "SELECT id as \"id: crate::ulid::ActiveBlockId\", block_type, content, parent_id as \"parent_id: crate::ulid::BlockId\", position,\n                deleted_at,\n                 todo_state, priority, due_date, scheduled_date,\n                page_id as \"page_id: crate::ulid::BlockId\"\n         FROM blocks b\n         WHERE block_type = ?1 AND deleted_at IS NULL\n           AND (?2 IS NULL OR id > ?3)\n           AND (?5 IS NULL OR b.space_id = ?5)\n           AND NOT EXISTS (\n                SELECT 1 FROM block_properties bp\n                WHERE bp.block_id = b.id\n                  AND bp.key = 'view_type'\n                  AND bp.value_text = 'query-view')\n         ORDER BY id ASC\n         LIMIT ?4",
