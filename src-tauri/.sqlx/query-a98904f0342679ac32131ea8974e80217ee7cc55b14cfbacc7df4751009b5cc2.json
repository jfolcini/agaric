  "query": "SELECT\n             b.id,\n             b.content AS title,\n             b.block_type,\n             (CASE WHEN b.deleted_at IS NOT NULL THEN 1 ELSE 0 END) AS \"deleted: bool\"\n           FROM blocks b\n           WHERE b.id IN (SELECT value FROM json_each(?1))\n             AND (?2 IS NULL OR b.space_id = ?2)",
