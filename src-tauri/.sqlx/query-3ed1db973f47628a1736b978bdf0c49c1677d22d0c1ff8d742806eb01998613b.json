{
  "db_name": "SQLite",
  "query": "SELECT id as \"id: crate::ulid::ActiveBlockId\", block_type, content, parent_id as \"parent_id: crate::ulid::BlockId\", position,\n                deleted_at,\n                 todo_state, priority, due_date, scheduled_date,\n                page_id as \"page_id: crate::ulid::BlockId\"\n         FROM blocks b\n         WHERE parent_id IS ?1 AND deleted_at IS NULL\n           AND (?2 IS NULL OR (\n                COALESCE(position, ?7) > ?3\n                OR (COALESCE(position, ?7) = ?3 AND id > ?4)))\n           AND (?6 IS NULL OR b.space_id = ?6)\n         ORDER BY COALESCE(position, ?7) ASC, id ASC\n         LIMIT ?5",
