{
  "db_name": "SQLite",
  "query": "SELECT id as \"id!: crate::ulid::BlockId\", block_type, content,\n                parent_id as \"parent_id: crate::ulid::BlockId\", position,\n                deleted_at,\n                 todo_state, priority, due_date, scheduled_date,\n                page_id as \"page_id: crate::ulid::BlockId\"\n         FROM blocks b\n         WHERE b.deleted_at IS NOT NULL\n           AND (\n                b.parent_id IS NULL\n                OR NOT EXISTS (\n                    SELECT 1 FROM blocks p\n                    WHERE p.id = b.parent_id AND p.deleted_at = b.deleted_at\n                )\n           )\n           AND (?1 IS NULL OR (\n                b.deleted_at < ?2 OR (b.deleted_at = ?2 AND b.id > ?3)))\n           AND (?5 IS NULL OR b.space_id = ?5)\n         ORDER BY b.deleted_at DESC, b.id ASC\n         LIMIT ?4",
