  "query": "SELECT id, block_type, content, parent_id, position,\n                deleted_at, todo_state, priority, due_date,\n                scheduled_date, page_id\n           FROM blocks\n           WHERE page_id = ?1\n             AND id != ?1\n             AND deleted_at IS NULL\n           ORDER BY COALESCE(position, ?2) ASC, id ASC\n           LIMIT ?3",
