  "query": "SELECT ol.device_id, ol.seq, ol.op_type, ol.payload, ol.created_at FROM op_log ol WHERE (?1 IS NULL OR ol.op_type = ?1) AND (?2 IS NULL OR ( ol.created_at < ?3 OR (ol.created_at = ?3 AND ol.seq < ?4) OR (ol.created_at = ?3 AND ol.seq = ?4 AND ol.device_id < ?6))) AND (?7 IS NULL OR ol.block_id IN ( SELECT id FROM blocks WHERE space_id = ?7)) ORDER BY ol.created_at DESC, ol.seq DESC, ol.device_id DESC LIMIT ?5",
