  "query": "SELECT\n             COALESCE(sb.parent_id, bl.source_id) AS \"source_page_id!\",\n             bl.target_id AS \"target_page_id!\",\n             COUNT(*) AS \"edge_count!\"\n         FROM block_links bl\n         JOIN blocks sb ON sb.id = bl.source_id\n         WHERE sb.deleted_at IS NULL\n         GROUP BY 1, 2",
