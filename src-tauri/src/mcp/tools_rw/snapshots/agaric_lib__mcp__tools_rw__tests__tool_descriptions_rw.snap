---
source: src/mcp/tools_rw/tests.rs
expression: wire
---
- description: "Append a content block under an existing parent. The block_type is always `content` — agents cannot create pages or tags through this tool."
  inputSchema:
    additionalProperties: false
    properties:
      content:
        description: Markdown content for the new block.
        type: string
      parent_id:
        description: ULID of the parent block (required — no orphan blocks).
        type: string
      position:
        description: Optional 1-based sibling position. Defaults to append (end).
        minimum: 1
        type: integer
      space_id:
        description: "ULID of the space the agent is operating in. The append is rejected with a Validation error if `parent_id`'s owning page lives in a different space."
        type: string
    required:
      - parent_id
      - content
      - space_id
    type: object
  name: append_block
- description: Replace the content of an existing block. Reversible via page history.
  inputSchema:
    additionalProperties: false
    properties:
      block_id:
        description: ULID of the block to edit.
        type: string
      content:
        description: New Markdown content.
        type: string
      space_id:
        description: "ULID of the space the agent is operating in. The edit is rejected with a Validation error if `block_id`'s owning page lives in a different space."
        type: string
    required:
      - block_id
      - content
      - space_id
    type: object
  name: update_block_content
- description: Set (upsert) a typed property on a block. Exactly one of value_text / value_num / value_date / value_ref / value_bool must be provided.
  inputSchema:
    additionalProperties: false
    properties:
      block_id:
        description: ULID of the target block.
        type: string
      key:
        description: Property key (see list_property_defs).
        type: string
      space_id:
        description: "ULID of the space the agent is operating in. The write is rejected with a Validation error if `block_id`'s owning page lives in a different space."
        type: string
      value_bool:
        description: "Boolean value (exactly one value_* must be set). #697 — for `value_type = 'boolean'` property definitions."
        type: boolean
      value_date:
        description: ISO-8601 date (exactly one value_* must be set).
        type: string
      value_num:
        description: Numeric value (exactly one value_* must be set).
        type: number
      value_ref:
        description: Block ULID reference (exactly one value_* must be set).
        type: string
      value_text:
        description: Text value (exactly one value_* must be set).
        type: string
    required:
      - block_id
      - key
      - space_id
    type: object
  name: set_property
- description: Apply an existing tag to a block. Does NOT create tags — the tag block must already exist (create tags from the UI).
  inputSchema:
    additionalProperties: false
    properties:
      block_id:
        description: ULID of the block to tag.
        type: string
      space_id:
        description: "ULID of the space the agent is operating in. The tag application is rejected with a Validation error if `block_id`'s owning page lives in a different space. (Tags themselves are global — `tag_id` is not space-scoped.)"
        type: string
      tag_id:
        description: ULID of an existing tag block.
        type: string
    required:
      - block_id
      - tag_id
      - space_id
    type: object
  name: add_tag
- description: "Create a new top-level page with the given title in the given space. The page has no parent (pages are always top-level in Agaric's model) and lands with its `space` property set in a single transaction."
  inputSchema:
    additionalProperties: false
    properties:
      space_id:
        description: "ULID of the space the new page belongs to. Required: every page lives in exactly one space; a page created without a `space_id` would be invisible to every space-scoped query."
        type: string
      title:
        description: "Page title (becomes the page's content)."
        type: string
    required:
      - title
      - space_id
    type: object
  name: create_page
- description: Soft-delete a block and its descendants. Reversible via page history (agents never get the non-reversible purge path).
  inputSchema:
    additionalProperties: false
    properties:
      block_id:
        description: ULID of the block to soft-delete.
        type: string
      space_id:
        description: "ULID of the space the agent is operating in. The delete is rejected with a Validation error if `block_id`'s owning page lives in a different space."
        type: string
    required:
      - block_id
      - space_id
    type: object
  name: delete_block
