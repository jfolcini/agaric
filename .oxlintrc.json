{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "jsx-a11y", "import"],
  "categories": {
    "correctness": "error"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "rules": {
    "eslint/no-unused-vars": [
      "error",
      { "args": "all", "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
    ],
    "typescript/no-non-null-assertion": "error",
    "eslint/prefer-const": "error",
    "unicorn/explicit-length-check": "error",
    "import/no-default-export": "error",
    "typescript/only-throw-error": "error",
    "typescript/require-await": "error",
    "eslint/no-console": ["warn", { "allow": ["warn", "error"] }],
    "eslint/complexity": ["warn", { "max": 25 }],

    "jsx-a11y/prefer-tag-over-role": "error",
    "react-hooks/exhaustive-deps": "error",
    "react-hooks/rules-of-hooks": "error",
    "jsx-a11y/control-has-associated-label": "error",
    "jsx-a11y/no-autofocus": "error",
    "jsx-a11y/interactive-supports-focus": "error",
    "eslint/no-unsafe-optional-chaining": "error",
    "jsx-a11y/no-noninteractive-element-interactions": "error",
    "unicorn/no-new-array": "error",
    "typescript/no-this-alias": "error",
    "jsx-a11y/role-supports-aria-props": "error",
    "unicorn/no-useless-fallback-in-spread": "error",
    "unicorn/prefer-string-starts-ends-with": "error",
    "jsx-a11y/no-static-element-interactions": "error",
    "jsx-a11y/click-events-have-key-events": "error",
    "unicorn/no-thenable": "error",
    "react/no-children-prop": "error",
    "react/no-array-index-key": "error",
    "unicorn/prefer-add-event-listener": "error",
    "react/no-object-type-as-default-prop": "error",
    "react/no-unstable-nested-components": "error",
    "eslint/no-unneeded-ternary": "error",
    "eslint/no-unexpected-multiline": "error",
    "unicorn/no-array-reverse": "error",

    "unicorn/no-array-sort": "error",
    "unicorn/switch-case-braces": "error",
    "react/jsx-boolean-value": "error",
    "eslint/arrow-body-style": "error",
    "typescript/consistent-type-definitions": "error",
    "typescript/consistent-generic-constructors": "error",
    "eslint/prefer-template": "error",
    "unicorn/prefer-dom-node-text-content": "error",
    "react/jsx-curly-brace-presence": "error",
    "unicorn/prefer-negative-index": "error",
    "typescript/prefer-function-type": "error",
    "eslint/prefer-arrow-callback": "error",
    "unicorn/text-encoding-identifier-case": "error",
    "typescript/consistent-indexed-object-style": "error",
    "unicorn/prefer-dom-node-append": "error",
    "unicorn/escape-case": "error",
    "unicorn/no-typeof-undefined": "error",
    "unicorn/prefer-math-min-max": "error",
    "eslint/no-else-return": "error",
    "unicorn/prefer-import-meta-properties": "error",
    "unicorn/prefer-at": "error"
  },
  "overrides": [
    {
      "files": ["src/main.tsx", "*.config.ts"],
      "rules": {
        "import/no-default-export": "off"
      }
    },
    {
      "files": ["**/__tests__/**", "**/*.test.ts", "**/*.test.tsx", "**/*.property.test.ts"],
      "rules": {
        "typescript/require-await": "off",
        "eslint/no-console": "off"
      }
    },
    {
      "files": ["scripts/**/*.js", "scripts/**/*.mjs", "scripts/**/*.cjs", "scripts/**/*.ts"],
      "rules": {
        "eslint/no-console": "off"
      }
    }
  ],
  "ignorePatterns": [
    "**/dist",
    "**/node_modules",
    "**/src-tauri/target",
    "**/src-tauri/gen",
    "**/.sqlx",
    "src/lib/bindings.ts",
    "src/editor/emoji-data.generated.ts",
    "**/coverage",
    "public/pdf.worker.min.mjs"
  ]
}
