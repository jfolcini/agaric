{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 25 }
        },
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUndeclaredDependencies": "error",
        "noUnusedFunctionParameters": "error"
      },
      "suspicious": {
        "useAwait": "error",
        "noEvolvingTypes": "error",
        "noConsole": {
          "level": "warn",
          "options": { "allow": ["warn", "error"] }
        },
        "noMisplacedAssertion": "error"
      },
      "style": {
        "noNonNullAssertion": "error",
        "useConst": "error",
        "useExplicitLengthCheck": "error",
        "noDefaultExport": "error",
        "useThrowOnlyError": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/src-tauri/target",
      "!**/src-tauri/gen",
      "!**/.sqlx",
      "!src/lib/bindings.ts",
      "!**/coverage",
      "!**/*.css",
      "!public/pdf.worker.min.mjs"
    ]
  },
  "overrides": [
    {
      "includes": ["src/main.tsx", "*.config.ts"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": ["**/__tests__/**", "**/*.test.ts", "**/*.test.tsx", "**/*.property.test.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "useAwait": "off",
            "noMisplacedAssertion": "off",
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
