# Supply-chain hardening (issue #816 — "stay on npm").
#
# ignore-scripts=true blocks npm from running dependency lifecycle
# scripts (pre/post-install) on `npm ci` / `npm install`. A
# freshly-compromised release can no longer execute arbitrary code at
# install time. Verified against package-lock.json (lockfileVersion 3,
# 806 packages): only 3 deps carry install scripts — esbuild and
# fsevents (×2) — and all three ship functional prebuilt binaries via
# optionalDependencies, so blocking their scripts is a no-op for the
# build. Explicit `npm run <script>` invocations are unaffected; only
# dependency lifecycle hooks are blocked.
#
# The root `postinstall` (playwright browser download) is removed from
# package.json — browsers are installed explicitly in scripts/setup.sh
# and the e2e CI job via `npx playwright install chromium`.
ignore-scripts=true

# engine-strict=true makes the `engines` range in package.json a hard
# gate: npm refuses to install under an unsupported Node/npm instead of
# warning. Keeps local + CI on the Node 24 line (.nvmrc / setup-node).
engine-strict=true
