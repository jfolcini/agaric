# Optional faster-linker config for local Rust builds (Linux).
#
# You normally DON'T need to copy this by hand: `scripts/setup.sh` (aka
# `npm run setup` / `just setup`) auto-writes `.cargo/config.toml` on Linux
# when a fast linker is on PATH — preferring `mold`, falling back to `lld`.
# This file is the reference / manual fallback.
#
# Why: the link step is the long pole of incremental Rust compiles on this
# codebase (~200K LOC + the Tauri/sqlx/Loro/rustls tree), not codegen. A faster
# linker cuts incremental relink time substantially (mold measured ~60% faster
# on this project, 2026-05-16; lld is close behind and ships on most CI/dev
# images already).
#
# Manual activation (only if setup.sh didn't wire it — e.g. you installed the
# linker afterwards):
#
#   sudo apt install mold      # Debian/Ubuntu (mold is in main since 22.04)
#   cp .cargo/config.toml.example .cargo/config.toml
#
# ...or just re-run `scripts/setup.sh`, which wires whichever of mold/lld it
# finds. Match the `[target.…]` triple to your host (`rustc -vV | grep host`).
# gcc/clang's `-fuse-ld=<ld>` gives a clear error if the linker isn't installed,
# never silent breakage.
#
# The active `.cargo/config.toml` is gitignored, so it never leaks into the
# tree — an unconditional linker flag would break a fresh clone that hasn't
# installed the linker yet. Linux-only: leave untouched on macOS/Windows. Safe
# to delete any time; it only affects the linker pick. Tracked in PEND-37.

# Preferred — mold:
[target.x86_64-unknown-linux-gnu]
rustflags = ["-C", "link-arg=-fuse-ld=mold"]

# Fallback — lld (uncomment instead of the mold block above if mold is absent):
# [target.x86_64-unknown-linux-gnu]
# rustflags = ["-C", "link-arg=-fuse-ld=lld"]
