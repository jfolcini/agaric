# Tauri
src-tauri/target/
src-tauri/gen/
# Generated per-target copies of bundled external binaries (see
# scripts/prepare-external-bins.mjs + tauri.conf.json → externalBin).
src-tauri/binaries/

# SQLx dev database (offline cache .sqlx/ is tracked)
src-tauri/dev.db
src-tauri/dev.db-*
src-tauri/.env
coverage/
# Per-shard vitest coverage dirs + the merged output produced by
# scripts/merge-vitest-coverage.mjs (CI consumes them as artifacts;
# local runs leave them in the tree).
coverage-shard-*/
coverage-merged/
# Rust llvm-cov outputs (cargo llvm-cov writes them under src-tauri/).
src-tauri/coverage.lcov
src-tauri/coverage-summary.json

# Playwright
test-results/
playwright-report/
blob-report/

# Lychee link-check cache (generated by `lychee --cache`; persisted in CI via actions/cache)
.lycheecache
worktrees/
UNDO-REDO-PLAN.md
agaric-release.apk
agaric-release.apk.idsig

# Claude Code runtime state (per-machine; settings.json + hooks/ are tracked)
.claude/scheduled_tasks.lock
.claude/settings.local.json
# Added by code-review-graph
.code-review-graph/

# Per-machine active cargo config (the staged `.example` is tracked;
# activating it makes the build depend on host-installed mold)
.cargo/config.toml
